SECRET_KEY=django-insecure-your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite (default, no config needed)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

